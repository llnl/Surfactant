{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ruff check",
      "type": "shell",
      "command": "uvx ruff check --output-format concise --color never",
      "problemMatcher": [
        {
          "owner": "Ruff",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "severity": "warning",
          "pattern": [
            {
              "regexp": "^(.*?):(\\d+):(\\d+):\\s+([A-Z]+\\d+)\\s+(.*)$",
              "file": 1,
              "line": 2,
              "column": 3,
              "code": 4,
              "message": 5
            }
          ]
        }
      ]
    }
  ]
}
